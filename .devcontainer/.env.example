# Copy this file to .env and fill in values before starting the container.
# cp .devcontainer/.env.example .devcontainer/.env

# Sets the compose project name, which prefixes volume names and is used
# as the container name. Use lowercase letters, digits, and hyphens only.
PROJECT_NAME=myproject

TZ=America/Los_Angeles

POSTGRES_DB=myproject
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
